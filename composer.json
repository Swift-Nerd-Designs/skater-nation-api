{
    "name": "jnv/api",
    "description": "JNV Training and Development — PHP API (CodeIgniter 4)",
    "type": "project",
    "require": {
        "php": "^8.1",
        "cloudinary/cloudinary_php": "*",
        "codeigniter4/framework": "^4.5",
        "dompdf/dompdf": "^2.0",
        "phpmailer/phpmailer": "*",
        "resend/resend-php": "*",
        "sentry/sentry": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "kint-php/kint": "^6.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "codeigniter4/devkit": true
        }
    },
    "minimum-stability": "stable"
}
