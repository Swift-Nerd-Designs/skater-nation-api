# ============================================================
# Client API — .env.example
# Copy to .env and fill in values. Never commit .env.
# ============================================================

CI_ENVIRONMENT = development

# App
app.baseURL         = http://localhost:8080/
app.allowedOrigins  = http://localhost:3000

# Database
database.default.hostname = localhost
database.default.database = client_db
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port      = 3307

# Contact form recipient
app.contactToEmail = hello@clientdomain.com

# Email via Resend (use contact.clientdomain.com subdomain)
RESEND_API_KEY =
RESEND_FROM    = noreply@contact.clientdomain.com

# Cloudinary (for server-side upload fallback — browser upload is preferred)
CLOUDINARY_CLOUD_NAME  =
CLOUDINARY_API_KEY     =
CLOUDINARY_API_SECRET  =

# ── Shop / Payments ─────────────────────────────────────────────────────────
# Public-facing site URL (used to build payment return/cancel URLs)
NUXT_SITE_URL = http://localhost:3000

# PayFast sandbox mode — set to 'false' in production
PAYFAST_TEST = true

# Ozow test mode — set to 'false' in production
OZOW_TEST = true

# ── Sentry error reporting ───────────────────────────────────────────────────
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# Leave blank in development to disable; required in production
SENTRY_DSN =

# ── Grafana Cloud — Loki log shipping ────────────────────────────────────────
# Get from: Grafana Cloud → Connections → Data sources → Loki → Details
# LOKI_URL format: https://logs-prod-<region>.grafana.net/loki/api/v1/push
LOKI_URL      =
LOKI_USER     =
LOKI_PASSWORD =
LOKI_APP_LABEL = skater-nation-api

# ── Test database (PHPUnit feature tests — never the dev DB) ─────────────────
# Create once: mysql -u root -P 3307 -h 127.0.0.1 -e "CREATE DATABASE IF NOT EXISTS client_cms_test;"
# Use 127.0.0.1 (TCP) not localhost (socket) — port is ignored with socket connections
database.tests.hostname = 127.0.0.1
database.tests.database = client_cms_test
database.tests.username = root
database.tests.password =
database.tests.port     = 3307
